# GENERAL
TZ=America/Toronto
PUID=1000
PGID=1000
TAILNET_SUFFIX={TAILNET_SUFFIX}
DOMAIN_BASE={DOMAIN_BASE}

# IMMICH CONFIGURATION
# You can find documentation for all the supported env variables at https://docs.immich.app/install/environment-variables
UPLOAD_LOCATION=./library # The location where your uploaded files are stored
DB_DATA_LOCATION=./postgres # The location where your database files are stored. Network shares are not supported for the database
# Connection secret for postgres. You should change it to a random password
DB_PASSWORD=postgres # Please use only the characters `A-Za-z0-9`, without special characters or spaces
IMMICH_VERSION=v2 # The Immich version to use. You can pin this to a specific version like "v2.1.0"
# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
